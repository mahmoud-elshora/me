{
  "version": 2,

  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],

  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },

    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },

    {
      "src": "/css/(.*)",
      "dest": "/public/css/$1"
    },

    {
      "src": "/js/(.*)",
      "dest": "/public/js/$1"
    },

    {
      "src": "/pages/(.*)",
      "dest": "/public/pages/$1.html"
    },

    {
      "src": "/(.*\\.[a-zA-Z0-9]+)",
      "dest": "/public/$1"
    },

    {
      "src": "/",
      "dest": "/public/index.html"
    },

    {
      "src": "/([^/]+)",
      "dest": "/public/pages/$1.html"
    }
  ],

  "headers": [
    {
      "source": "/(.*\\.(css|js|png|jpg|jpeg|svg|ico|woff2))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },

    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },

    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
